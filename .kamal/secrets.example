# Kamal secrets configuration
# Copy this file to .kamal/secrets and fill in your actual values
# NEVER commit .kamal/secrets to version control!

# Docker Hub credentials (or other registry)
KAMAL_REGISTRY_PASSWORD=your_docker_hub_token

# Rails master key (from config/master.key)
RAILS_MASTER_KEY=your_rails_master_key

# PostgreSQL password
POSTGRES_PASSWORD=your_secure_postgres_password
STEM_APP_DATABASE_PASSWORD=your_secure_postgres_password
