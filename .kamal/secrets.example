# Secrets for Kamal deployment
# Copy to .kamal/secrets and fill in ALL values
# NEVER commit .kamal/secrets to version control!

# ---- VPS / Server ----
VPS_IP=your_server_ip
APP_DOMAIN=your-domain.com

# ---- Docker Registry (GitHub Container Registry) ----
DOCKER_REGISTRY_USERNAME=your_github_username
KAMAL_REGISTRY_PASSWORD=ghp_xxxxxxxxxxxxxxxxxxxx

# ---- Rails ----
RAILS_MASTER_KEY=your_rails_master_key

# ---- Database ----
POSTGRES_PASSWORD=a_secure_random_password
STEM_APP_DATABASE_PASSWORD=$POSTGRES_PASSWORD
DB_HOST=stem-app-db
